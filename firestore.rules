rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isSelf(userId);
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isSelf(userId);
    }

    match /shared_wallets/{walletId} {
      allow create: if signedIn() &&
        request.resource.data.ownerUid == request.auth.uid;
      allow read, update, delete: if signedIn() &&
        request.auth.uid in resource.data.memberIds;
    }

    match /shared_wallets/{walletId}/entries/{entryId} {
      allow read, write: if signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/shared_wallets/$(walletId)).data.memberIds;
    }

    match /shared_wallet_invites_by_email/{email}/invites/{walletId} {
      allow read: if signedIn() && request.auth.token.email == email;
      allow create: if signedIn() &&
        request.resource.data.inviterUid == request.auth.uid &&
        get(/databases/$(database)/documents/shared_wallets/$(walletId)).data.ownerUid == request.auth.uid;
      allow delete: if signedIn() &&
        (request.auth.token.email == email || resource.data.inviterUid == request.auth.uid);
    }
  }
}
